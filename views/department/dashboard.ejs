<%- include('../layout/header') %>

<div class="hero-bg-mask" style="opacity: 0.1;"></div>

<div class="relative z-10">
    <div class="glass-card mb-4 d-flex justify-content-between align-items-center animate-fade-in">
        <div>
            <h2 class="mb-1 fw-bold tracking-tighter">Department Portal</h2>
            <p class="text-zinc-500 mb-0 small uppercase tracking-widest">Active Resolution Queue</p>
        </div>
        <div class="badge-zinc">
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
            </span>
            Connected: District HQ
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden animate-fade-in delay-200">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Ref</th>
                        <th>Issue Summary</th>
                        <th>Citizen Contact</th>
                        <th>Workflow State</th>
                        <th class="pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (complaints && complaints.length > 0) { %>
                        <% complaints.forEach(complaint => { %>
                            <tr>
                                <td class="ps-4"><small class="text-zinc-500 font-monospace">#<%= complaint._id.toString().substring(18) %></small></td>
                                <td>
                                    <div class="fw-bold mb-1"><%= complaint.subject %></div>
                                    <div class="text-zinc-500 small" style="max-width:400px;"><%= complaint.description.substring(0, 80) %>...</div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <i data-lucide="phone" style="width: 14px; color: var(--zinc-500);"></i>
                                        <span class="small"><%= complaint.phoneNumber %></span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge-zinc">
                                        <i data-lucide="activity" class="text-saffron" style="width: 10px;"></i>
                                        <%= complaint.status %>
                                    </span>
                                </td>
                                <td class="pe-4 text-end">
                                    <% if(['Pending', 'Reopened', 'FAILED'].includes(complaint.status)) { %>
                                        <form action="/department/<%= complaint._id %>/resolve" method="POST" style="display:inline;">
                                            <button type="submit" class="btn-zinc btn-sm py-2 px-3 d-inline-flex align-items-center gap-2" style="font-size: 0.75rem;">
                                                <i data-lucide="check-circle-2" style="width: 14px;"></i> Mark Resolved
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <div class="text-zinc-500 small d-inline-flex align-items-center gap-1">
                                            <i data-lucide="lock" style="width: 12px;"></i> Locked
                                        </div>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="5" class="text-center py-5 text-zinc-500">Workspace is empty. No active grievances.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../layout/footer') %>
