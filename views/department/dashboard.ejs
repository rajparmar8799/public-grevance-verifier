<%- include('../layout/header') %>

<div class="container-custom">
    <h3>Department Dashboard</h3>
    <p class="text-muted">Manage complaints and mark them resolved.</p>

    <% if (complaints && complaints.length > 0) { %>
        <table class="table table-bordered table-striped mt-3">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Date</th>
                    <th>Subject & Description</th>
                    <th>Contact</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% complaints.forEach(complaint => { %>
                    <tr>
                        <td><%= complaint._id.toString().substring(0, 8) %></td>
                        <td><%= new Date(complaint.createdAt).toLocaleDateString() %></td>
                        <td>
                            <b><%= complaint.subject %></b><br>
                            <small class="text-muted"><%= complaint.description %></small>
                        </td>
                        <td><%= complaint.phoneNumber %></td>
                        <td>
                            <span class="badge-status badge-<%= complaint.status.replace(' ', '-') %>"><%= complaint.status %></span>
                        </td>
                        <td>
                            <% if(complaint.status === 'Pending' || complaint.status === 'Reopened') { %>
                                <form action="/department/<%= complaint._id %>/resolve" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success">Mark Resolved</button>
                                </form>
                            <% } else { %>
                                <button class="btn btn-sm btn-secondary" disabled>Resolved</button>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <div class="alert alert-info mt-4">
            No complaints available.
        </div>
    <% } %>
</div>

<%- include('../layout/footer') %>
