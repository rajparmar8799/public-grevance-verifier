<%- include('../layout/header') %>

<div class="hero-bg-mask" style="opacity: 0.1;"></div>

<div class="row justify-content-center relative z-10">
    <div class="col-md-7">
        <div class="glass-card animate-fade-in">
            <div class="d-flex align-items-center mb-5">
                <a href="/citizen" class="btn-zinc-outline p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i data-lucide="chevron-left"></i>
                </a>
                <div>
                    <h3 class="mb-0 fw-bold tracking-tighter">Submit Grievance</h3>
                    <p class="text-zinc-500 mb-0 small uppercase tracking-widest">New Entry</p>
                </div>
            </div>
            
            <form action="/citizen/new" method="POST" class="space-y-6">
                <div class="mb-4">
                    <label class="form-label small fw-bold text-zinc-400 ls-1 mb-2">SUBJECT MATTER</label>
                    <input type="text" class="form-control" name="subject" placeholder="Summarize the core issue" required>
                </div>
                
                <div class="mb-4">
                    <label class="form-label small fw-bold text-zinc-400 ls-1 mb-2">DIRECT CONTACT (FOR CALL VERIFICATION)</label>
                    <div class="input-group" style="border-radius: 12px;">
                        <span class="input-group-text bg-zinc-900 text-zinc-500 border-0" style="border-radius: 12px 0 0 12px;">+91</span>
                        <input type="text" class="form-control border-start-0" name="phoneNumber" placeholder="9876543210" style="border-radius: 0 12px 12px 0;" inputmode="numeric" required>
                    </div>
                </div>

                <div class="mb-5">
                    <label class="form-label small fw-bold text-zinc-400 ls-1 mb-2">DETAILED DESCRIPTION</label>
                    <textarea class="form-control" name="description" rows="5" placeholder="Provide context, location details, and expected resolution..." required></textarea>
                </div>

                <div class="stats-card p-4 mb-5 border border-white border-opacity-5">
                    <div class="d-flex align-items-start gap-3">
                        <i data-lucide="shield-alert" class="text-saffron flex-shrink-0" style="width: 24px; height: 24px; margin-top: 2px;"></i>
                        <div class="small text-zinc-400 leading-relaxed">
                            <span class="text-white fw-bold d-block mb-1">Verification Policy:</span>
                            An automated IVR call will be triggered upon resolution. Ensure the provided number is active for confirmation.
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-zinc w-100 py-3 d-flex align-items-center justify-content-center gap-2 fw-bold">
                    Submit to Swagat Workspace
                    <i data-lucide="send" style="width: 16px;"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<%- include('../layout/footer') %>
